# Public site URL — no trailing slash; match your canonical host (apex: https://xircons.website, not www).
# On Vercel: set for Production and redeploy so metadata, sitemap, and robots use the correct origin.
NEXT_PUBLIC_SITE_URL=https://xircons.website

# Optional: Google Search Console HTML tag verification (content value only, not the full tag).
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Contact form (Resend) — server-only; set on Vercel for Production and redeploy.
# Verify your domain in Resend and use a verified sender for CONTACT_FROM_EMAIL.
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_FROM_EMAIL=Contact <contact@xircons.website>
# CONTACT_TO_EMAIL=wutthikan_s@cmu.ac.th
